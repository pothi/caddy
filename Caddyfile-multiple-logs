# To have two log files with different formats (json and another)
# source - https://caddyserver.com/docs/caddyfile/directives/log#examples
{
	log access-formatted {
		include http.log.access.example
		output file /var/log/access-example.log
		format console
	}

	log access-json {
		include http.log.access.example
		output file /var/log/access-example.json
		format json
	}
}

example.com {
	log example
}

